{
    "rules": {
        ".read": "auth != null",
        ".write": "auth != null",
        "matches": {
            "$matchId": {
                "meta": {
                    "poolIndexA": {
                        ".validate": "!data.exists() || (newData.isNumber() && newData.val() == data.val() + 1)"
                    },
                    "poolIndexB": {
                        ".validate": "!data.exists() || (newData.isNumber() && newData.val() == data.val() + 1)"
                    }
                },
                "teams": {
                    "$teamId": {
                        "score": {
                            ".validate": "!data.exists() || (newData.isNumber() && newData.val() == data.val() + 1)"
                        },
                        "towers": {
                            "$towerId": {
                                "claimedBy": {
                                    ".validate": "!newData.exists() || newData.val() == null || newData.val().beginsWith('bot_') || (newData.val() == auth.uid && root.child('matches').child($matchId).child('players').child(auth.uid).child('team').val() === $teamId)"
                                },
                                "solvedBy": {
                                    ".validate": "!newData.exists() || newData.val() == null || newData.val().beginsWith('bot_') || (newData.val() == auth.uid && root.child('matches').child($matchId).child('players').child(auth.uid).child('team').val() === $teamId)"
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}